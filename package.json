{
  "name": "velo-pos",
  "version": "1.20.0",
  "description": "Sistema POS desktop profesional para comercios, repuestos, sucursales y operaciones empresariales",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3 --arch x64",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "db:reset": "node scripts/resetDB.js",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "verify-version": "node -e \"const v=require('./package.json').version; console.log('Version:',v); if(!v) process.exit(1)\"",
    "release": "npm run release:check && npm run build:win",
    "tag": "node scripts/createReleaseTag.js",
    "release:check": "node scripts/release-check.js",
    "verify:integrity": "ELECTRON_RUN_AS_NODE=1 electron scripts/verify-historical-integrity.js",
    "verify:marker": "node scripts/check-historical-marker.js",
    "verify:packaging": "node scripts/check-packaging.js",
    "test:import": "ELECTRON_RUN_AS_NODE=1 electron scripts/test-import-hardening.js",
    "test:financial": "ELECTRON_RUN_AS_NODE=1 electron scripts/test-financial-core.js",
    "test:business": "ELECTRON_RUN_AS_NODE=1 electron scripts/test-multi-business-detached-db.js",
    "test:url": "node scripts/test-url-safe.js",
    "test:login": "node scripts/test-login-rate.js",
    "test": "npm run test:url && npm run test:login && npm run test:business && npm run test:import && npm run test:financial"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "do.velopos.app",
    "productName": "Velo POS",
    "copyright": "Copyright 2026 — Velo POS",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "lib/**/*",
      "main.js",
      "preload.js",
      "database.js",
      "versioning.js",
      "logger.js",
      "license.js",
      "!**/.DS_Store",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!dist/**",
      "!data/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Velo POS",
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "dobleumediado-oss",
      "repo": "velo-pos",
      "releaseType": "release"
    }
  }
}
