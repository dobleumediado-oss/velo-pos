{
  "name": "velo-pos",
  "version": "1.1.0",
  "description": "Sistema POS para micro negocios — República Dominicana",
  "main": "main.js",
  "scripts": {
    "start": "npx @electron/rebuild -f -w better-sqlite3 --arch x64 --quiet 2>/dev/null; electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3 --arch x64",
    "db:reset": "node scripts/resetDB.js",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "do.velopos.app",
    "productName": "Velo POS",
    "copyright": "Copyright 2026 — Velo POS",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "main.js",
      "preload.js",
      "database.js",
      "versioning.js",
      "license.js",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!dist/**",
      "!data/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Velo POS",
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "dobleumediado-oss",
      "repo": "velo-pos",
      "private": true
    }
  }
}
